# Chief of Staff — environment variables
# Copy this file to .env and fill in your values:
#     cp .env.example .env
#
# .env is gitignored — never commit it with real credentials.

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — required for Claude routing (run_agent, general_query intents)
ANTHROPIC_API_KEY=sk-ant-...


# ── Optional — paths ──────────────────────────────────────────────────────────
# Override if your workspace is not at ~/Documents/claude-workspace/

# WORKSPACE_ROOT=~/Documents/claude-workspace
# COS_PROJECT_ROOT=~/Documents/claude-workspace/projects/chief-of-staff

# Source project directories — verified against SERVER_REGISTRY.md on M1 deployment
# TASK_AGENTS_DIR=~/Documents/claude-workspace/projects/task-agents
# REFLIB_AGENT_DIR=~/Documents/claude-workspace/projects/reflib-agent
# AGENTIC_INBOX_DIR=~/Documents/claude-workspace/projects/agentic-inbox
# GILLY_JOBS_DIR=~/Documents/claude-workspace/projects/gilly-jobs


# ── Optional — service config ─────────────────────────────────────────────────

# COS_PORT=5009
# COS_HOST=127.0.0.1

# supervisord XML-RPC endpoint (must match inet_http_server in supervisord.conf)
# SUPERVISORD_URL=http://localhost:9001/RPC2

# Ollama base URL (Ollama default — only change if you moved the port)
# OLLAMA_BASE_URL=http://localhost:11434


# ── Optional — LLM models ─────────────────────────────────────────────────────
# Run `ollama list` on M1 to verify OLLAMA_CLASSIFY_MODEL is available.
# Swap to a model that's actually installed if llama3.2 is not present.

# OLLAMA_CLASSIFY_MODEL=llama3.2
# CLAUDE_MODEL=claude-sonnet-4-20250514


# ── Optional — scheduler ──────────────────────────────────────────────────────

# SCHEDULER_TIMEZONE=America/Toronto


# ── Optional — voice layer ────────────────────────────────────────────────────

# Whisper model size: tiny / base / small / medium / large-v3
# WHISPER_MODEL_SIZE=medium
# WHISPER_LANGUAGE=en

# Push-to-talk keyboard shortcut in pynput format
# WHISPER_LANGUAGE=en
# PTT_HOTKEY=<cmd>+<shift>+<space>

# CoS command endpoint (voice app posts transcripts here)
# COS_COMMAND_URL=http://localhost:5009/command


# ── Optional — gilly-jobs ──────────────────────────────────────────────────────

# supervisord program name — must match the `name` field in services.yaml
# GILLY_JOBS_SERVICE_NAME=gilly-jobs
# Timeout in seconds before CoS gives up waiting for gilly-jobs to complete
# GILLY_JOBS_TIMEOUT=600


# ── Optional — logging ────────────────────────────────────────────────────────

# LOG_LEVEL=INFO
